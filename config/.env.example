# Copy this file to .env.prod and fill in real values
# .env.prod is gitignored — never commit it

URL=https://coffeeandpeppers.com
cpURL=https://coffeeandpeppers.com

# Direct URL of a real product to use for checkout tests.
# Pick something simple (no variations), cheap, always in stock.
# Bac Water 2ML is a good default — simple product, always stocked.
TEST_PRODUCT_URL=https://coffeeandpeppers.com/shop/products/bac-water-2ml/

# WP-CLI teardown — used by wp.utils.ts to delete test orders after each run
WP_PATH=/home/u748382507/domains/darkslategray-fish-207364.hostingersite.com/public_html
SSH_HOST=<hostinger-server-ip-or-hostname>
SSH_USER=u748382507
